---
const navLinks = [
  { href: '/#about', label: 'About' },
  { href: '/#lessons', label: 'Lessons' },
  { href: '/#pricing', label: 'Pricing' },
  { href: '/#faq', label: 'FAQ' },
  { href: '/blog', label: 'Blog' },
  { href: '/sheet-music', label: 'Sheet Music' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-md border-b border-navy-100 shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between" aria-label="Main navigation">
    <a href="#" class="flex items-center gap-2 font-semibold text-lg text-navy-900 hover:text-gold-500 transition-colors">
      <!-- Treble clef icon -->
      <svg class="w-8 h-8 text-gold-500" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 3c-.5 0-1 .19-1.41.59L8.71 5.47c-.2.2-.3.44-.3.71v1.64c0 .55.45 1 1 1h.18C10.4 11.86 12 14.81 12 18c0 .55.45 1 1 1s1-.45 1-1c0-3.19 1.6-6.14 2.41-9.18h.18c.55 0 1-.45 1-1V6.18c0-.27-.11-.52-.3-.71l-1.88-1.88C14 3.19 13.5 3 13 3h-1zm0 2l1.59 1.59c.09.09.2.16.32.2L12 12.64l-1.91-5.85c.12-.04.23-.11.32-.2L12 5z"/>
      </svg>
      <span>Sandycove School of Music</span>
    </a>

    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="px-3 py-2 rounded-md text-sm font-medium text-navy-600 hover:text-navy-900 hover:bg-navy-50 transition-colors"
        >
          {label}
        </a>
      ))}
      <a
        href="#contact"
        class="ml-3 px-5 py-2 rounded-full text-sm font-semibold bg-gold-500 text-white hover:bg-gold-600 transition-colors shadow-sm"
      >
        Book a Lesson
      </a>
    </div>

    <button
      id="menu-toggle"
      class="md:hidden p-2 rounded-md text-navy-600 hover:bg-navy-50 transition-colors"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-navy-100 bg-white" role="navigation" aria-label="Mobile navigation">
    <div class="px-4 py-3 space-y-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="block px-3 py-2 rounded-md text-sm font-medium text-navy-600 hover:text-navy-900 hover:bg-navy-50 transition-colors"
        >
          {label}
        </a>
      ))}
      <a
        href="#contact"
        class="block px-3 py-2 rounded-full text-sm font-semibold bg-gold-500 text-white hover:bg-gold-600 transition-colors text-center mt-2"
      >
        Book a Lesson
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  menu.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    })
  );
</script>
