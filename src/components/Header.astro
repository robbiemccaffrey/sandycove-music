---
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#lessons', label: 'Lessons' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed top-0 w-full z-50 bg-navy-950/90 backdrop-blur-md border-b border-white/10">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between" aria-label="Main navigation">
    <a href="#" class="font-semibold text-lg text-white hover:text-gold-400 transition-colors">
      Sandycove School of Music
    </a>

    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="px-3 py-2 rounded-md text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 transition-colors"
        >
          {label}
        </a>
      ))}
      <a
        href="#contact"
        class="ml-3 px-4 py-2 rounded-md text-sm font-semibold bg-gold-500 text-navy-950 hover:bg-gold-400 transition-colors"
      >
        Book a Lesson
      </a>
    </div>

    <button
      id="menu-toggle"
      class="md:hidden p-2 rounded-md text-gray-300 hover:bg-white/10 transition-colors"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10" role="navigation" aria-label="Mobile navigation">
    <div class="px-4 py-3 space-y-1">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="block px-3 py-2 rounded-md text-sm font-medium text-gray-300 hover:text-white hover:bg-white/10 transition-colors"
        >
          {label}
        </a>
      ))}
      <a
        href="#contact"
        class="block px-3 py-2 rounded-md text-sm font-semibold bg-gold-500 text-navy-950 hover:bg-gold-400 transition-colors text-center mt-2"
      >
        Book a Lesson
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  menu.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    })
  );
</script>
