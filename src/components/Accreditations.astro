---
const accreditations = [
  { name: 'RIAM', full: 'Royal Irish Academy of Music' },
  { name: 'ABRSM', full: 'Associated Board of the Royal Schools of Music' },
  { name: 'Trinity', full: 'Trinity College London' },
];
---

<section class="py-12 bg-navy-900/50 border-y border-white/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm text-gray-400 uppercase tracking-widest mb-8">Accredited Exam Preparation</p>
    <div class="flex flex-wrap justify-center items-center gap-8 sm:gap-16">
      {accreditations.map(({ name, full }) => (
        <div class="text-center" title={full}>
          <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-full bg-white/10 border border-white/20 flex items-center justify-center mx-auto mb-2">
            <span class="text-xl sm:text-2xl font-bold text-gold-400">{name}</span>
          </div>
          <p class="text-xs text-gray-400 max-w-[120px]">{full}</p>
        </div>
      ))}
    </div>
  </div>
</section>
