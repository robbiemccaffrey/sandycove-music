---
---

<section id="about" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-4" style="font-family: 'Playfair Display', Georgia, serif;">Piano Lessons in Dun Laoghaire</h2>
      <div class="w-16 h-1 bg-gold-500 mx-auto"></div>
    </div>
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-navy-700 leading-relaxed mb-6">
          At Sandycove School of Music, we believe in providing tailored, effective tutoring to help every student reach their full potential. Whether you're a complete beginner or preparing for grade exams, our approach is personalised to your goals and learning style.
        </p>
        <p class="text-navy-700 leading-relaxed mb-6">
          Our teachers hold a BA in Music and bring over 25 years of combined teaching experience. We specialise in piano tuition across classical, jazz, contemporary, and pop styles, preparing students for RIAM, ABRSM, and Trinity College London examinations.
        </p>
        <p class="text-navy-700 leading-relaxed mb-8">
          Located in the heart of Dun Laoghaire, we offer a welcoming and supportive environment where students of all ages and abilities can develop their musical skills and confidence.
        </p>
        <div class="flex flex-wrap gap-4">
          <div class="flex items-center gap-2 text-sm text-navy-600 bg-navy-50 px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-gold-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
            25+ years experience
          </div>
          <div class="flex items-center gap-2 text-sm text-navy-600 bg-navy-50 px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-gold-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3v10.55A4 4 0 1014 17V7h4V3h-6z"/></svg>
            BA in Music
          </div>
          <div class="flex items-center gap-2 text-sm text-navy-600 bg-navy-50 px-4 py-2 rounded-full">
            <svg class="w-4 h-4 text-gold-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            All grades &amp; levels
          </div>
        </div>
      </div>
      <div class="relative">
        <!-- Musical illustration -->
        <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-navy-50 to-navy-100 border border-navy-200 flex items-center justify-center overflow-hidden relative">
          <!-- Grand piano illustration -->
          <svg class="w-48 h-48 text-navy-800" viewBox="0 0 200 200" fill="none" stroke="currentColor" stroke-width="2">
            <!-- Piano body -->
            <path d="M30 120 C30 80 40 50 100 40 C160 50 170 80 170 120 L170 145 L30 145 Z" fill="currentColor" opacity="0.08" stroke="currentColor" stroke-width="2"/>
            <!-- Keyboard -->
            <rect x="50" y="145" width="100" height="25" rx="2" fill="white" stroke="currentColor" stroke-width="1.5"/>
            <!-- White keys -->
            <line x1="64" y1="145" x2="64" y2="170" stroke="currentColor" stroke-width="0.8"/>
            <line x1="78" y1="145" x2="78" y2="170" stroke="currentColor" stroke-width="0.8"/>
            <line x1="92" y1="145" x2="92" y2="170" stroke="currentColor" stroke-width="0.8"/>
            <line x1="106" y1="145" x2="106" y2="170" stroke="currentColor" stroke-width="0.8"/>
            <line x1="120" y1="145" x2="120" y2="170" stroke="currentColor" stroke-width="0.8"/>
            <line x1="134" y1="145" x2="134" y2="170" stroke="currentColor" stroke-width="0.8"/>
            <!-- Black keys -->
            <rect x="59" y="145" width="9" height="15" rx="1" fill="currentColor" opacity="0.7"/>
            <rect x="73" y="145" width="9" height="15" rx="1" fill="currentColor" opacity="0.7"/>
            <rect x="101" y="145" width="9" height="15" rx="1" fill="currentColor" opacity="0.7"/>
            <rect x="115" y="145" width="9" height="15" rx="1" fill="currentColor" opacity="0.7"/>
            <rect x="129" y="145" width="9" height="15" rx="1" fill="currentColor" opacity="0.7"/>
            <!-- Music stand -->
            <rect x="80" y="55" width="40" height="30" rx="2" fill="white" stroke="currentColor" stroke-width="1.5"/>
            <!-- Notes on stand -->
            <circle cx="90" cy="67" r="2.5" fill="currentColor" opacity="0.4"/>
            <line x1="92.5" y1="67" x2="92.5" y2="57" stroke="currentColor" opacity="0.4" stroke-width="1.2"/>
            <circle cx="100" cy="72" r="2.5" fill="currentColor" opacity="0.4"/>
            <line x1="102.5" y1="72" x2="102.5" y2="62" stroke="currentColor" opacity="0.4" stroke-width="1.2"/>
            <circle cx="110" cy="65" r="2.5" fill="currentColor" opacity="0.4"/>
            <line x1="112.5" y1="65" x2="112.5" y2="55" stroke="currentColor" opacity="0.4" stroke-width="1.2"/>
            <!-- Legs -->
            <line x1="60" y1="170" x2="55" y2="190" stroke="currentColor" stroke-width="2.5"/>
            <line x1="140" y1="170" x2="145" y2="190" stroke="currentColor" stroke-width="2.5"/>
          </svg>
          <!-- Floating notes decoration -->
          <svg class="absolute top-4 right-4 w-8 h-8 text-gold-400 opacity-60" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 3v10.55A4 4 0 1014 17V7h4V3h-6z"/>
          </svg>
          <svg class="absolute bottom-8 left-4 w-6 h-6 text-gold-400 opacity-40" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
