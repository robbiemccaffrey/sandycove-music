---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-navy-950 mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <div>
        <h3 class="text-lg font-semibold text-white mb-3">Sandycove School of Music</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Tailored, effective tutoring to help you reach your potential.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-3">Location</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Albert Park<br />
          Dun Laoghaire<br />
          Co. Dublin, A96
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-3">Contact</h3>
        <a
          href="mailto:info@sandycoveschoolofmusic.com"
          class="text-gold-400 hover:text-gold-300 text-sm transition-colors"
        >
          info@sandycoveschoolofmusic.com
        </a>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 text-center">
      <p class="text-sm text-gray-500">
        &copy; {year} Sandycove School of Music. All rights reserved.
      </p>
    </div>
  </div>
</footer>
