---
// ChatWidget.astro — Intercom-style chat widget
// Two modes: Chat (AI bot) and Contact Form (leave a message)
---

<div id="chat-widget">
  <button id="chat-bubble" aria-label="Open chat">
    <svg id="chat-bubble-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <svg id="chat-bubble-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <div id="chat-panel" class="chat-hidden">
    <div id="chat-header">
      <div id="chat-header-inner">
        <div id="chat-avatar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        </div>
        <div id="chat-header-text">
          <span id="chat-header-title">Sandycove Music</span>
          <span id="chat-header-sub">We typically reply instantly</span>
        </div>
      </div>
      <button id="chat-close" aria-label="Close chat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div id="chat-tabs">
      <button class="chat-tab active" data-tab="chat">Chat</button>
      <button class="chat-tab" data-tab="contact">Leave a message</button>
    </div>

    <div id="chat-view">
      <div id="chat-messages"></div>
      <div id="chat-input-area">
        <input type="text" id="chat-input" placeholder="Write a reply..." maxlength="500" autocomplete="off">
        <button id="chat-send" aria-label="Send message">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
        </button>
      </div>
    </div>

    <div id="contact-view" class="chat-hidden">
      <div id="contact-form-wrapper">
        <p id="contact-intro">Prefer to leave a message? We'll get back to you by email.</p>
        <form id="chat-contact-form" novalidate>
          <label for="cf-name">Name <span class="cf-req">*</span></label>
          <input type="text" id="cf-name" name="name" required maxlength="200" autocomplete="name" placeholder="Your name">
          <label for="cf-email">Email <span class="cf-req">*</span></label>
          <input type="email" id="cf-email" name="email" required maxlength="200" autocomplete="email" placeholder="you@example.com">
          <label for="cf-phone">Phone <span class="cf-opt">(optional)</span></label>
          <input type="tel" id="cf-phone" name="phone" maxlength="50" autocomplete="tel" placeholder="086 ...">
          <label for="cf-message">Message <span class="cf-req">*</span></label>
          <textarea id="cf-message" name="message" required maxlength="5000" rows="3" placeholder="How can we help?"></textarea>
          <button type="submit" id="cf-submit">Send message</button>
          <div id="cf-status"></div>
        </form>
      </div>
    </div>

    <div id="chat-footer">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      <span>Sandycove School of Music</span>
    </div>
  </div>
</div>

<style>
  #chat-widget {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* Bubble */
  #chat-bubble {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a1a2e 0%, #2d2d4e 100%);
    color: #d4a843;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(26, 26, 46, 0.4);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  #chat-bubble:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(26, 26, 46, 0.5);
  }

  /* Panel */
  #chat-panel {
    position: absolute;
    bottom: 74px;
    right: 0;
    width: 380px;
    height: 560px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 5px 40px rgba(0, 0, 0, 0.16);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  #chat-panel.chat-hidden { display: none; }

  /* Header */
  #chat-header {
    background: linear-gradient(135deg, #1a1a2e 0%, #16162b 100%);
    color: #fff;
    padding: 16px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-shrink: 0;
  }
  #chat-header-inner {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  #chat-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(212, 168, 67, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #d4a843;
    flex-shrink: 0;
  }
  #chat-header-text {
    display: flex;
    flex-direction: column;
  }
  #chat-header-title {
    font-weight: 600;
    font-size: 0.95rem;
  }
  #chat-header-sub {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.55);
    margin-top: 1px;
  }
  #chat-close {
    background: none;
    border: none;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    transition: color 0.15s;
  }
  #chat-close:hover { color: #fff; }

  /* Tabs */
  #chat-tabs {
    display: flex;
    border-bottom: 1px solid #f0f0f0;
    flex-shrink: 0;
    background: #fafafa;
  }
  .chat-tab {
    flex: 1;
    padding: 10px 8px;
    border: none;
    background: none;
    cursor: pointer;
    font-size: 0.8rem;
    font-family: inherit;
    color: #999;
    border-bottom: 2px solid transparent;
    transition: all 0.15s;
  }
  .chat-tab:hover { color: #555; }
  .chat-tab.active {
    color: #1a1a2e;
    font-weight: 600;
    border-bottom-color: #d4a843;
  }

  /* Chat view */
  #chat-view {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
  }
  #chat-view.chat-hidden { display: none; }

  #chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: #fff;
  }

  /* Message wrappers */
  .chat-msg-group {
    display: flex;
    gap: 8px;
    max-width: 88%;
  }
  .chat-msg-group.assistant { align-self: flex-start; }
  .chat-msg-group.user {
    align-self: flex-end;
    flex-direction: row-reverse;
  }

  .chat-msg-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    margin-top: 2px;
  }
  .chat-msg-group.assistant .chat-msg-avatar {
    background: #1a1a2e;
    color: #d4a843;
  }
  .chat-msg-group.user .chat-msg-avatar {
    background: #e8e8ed;
    color: #555;
  }

  .chat-msg-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .chat-msg-bubble {
    padding: 10px 14px;
    font-size: 0.88rem;
    line-height: 1.5;
    word-wrap: break-word;
  }
  .chat-msg-group.assistant .chat-msg-bubble {
    background: #f1f1f4;
    color: #1a1a2e;
    border-radius: 4px 16px 16px 16px;
  }
  .chat-msg-group.user .chat-msg-bubble {
    background: #1a1a2e;
    color: #fff;
    border-radius: 16px 4px 16px 16px;
  }

  /* Typing indicator */
  .chat-typing {
    align-self: flex-start;
    display: flex;
    gap: 8px;
    max-width: 88%;
  }
  .chat-typing-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #1a1a2e;
    color: #d4a843;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .chat-typing-dots {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 12px 16px;
    background: #f1f1f4;
    border-radius: 4px 16px 16px 16px;
  }
  .chat-typing-dots span {
    width: 7px;
    height: 7px;
    background: #bbb;
    border-radius: 50%;
    animation: chatBounce 1.2s infinite;
  }
  .chat-typing-dots span:nth-child(2) { animation-delay: 0.15s; }
  .chat-typing-dots span:nth-child(3) { animation-delay: 0.3s; }

  @keyframes chatBounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  /* Input area */
  #chat-input-area {
    display: flex;
    align-items: center;
    padding: 12px 14px;
    border-top: 1px solid #f0f0f0;
    background: #fff;
    flex-shrink: 0;
    gap: 8px;
  }
  #chat-input {
    flex: 1;
    border: 1px solid #e5e5e5;
    border-radius: 20px;
    padding: 10px 16px;
    font-size: 0.88rem;
    font-family: inherit;
    outline: none;
    background: #fafafa;
    transition: border-color 0.15s, background 0.15s;
  }
  #chat-input:focus {
    border-color: #d4a843;
    background: #fff;
  }
  #chat-send {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #1a1a2e;
    color: #fff;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.15s;
  }
  #chat-send:hover { background: #2d2d4e; }

  /* Footer */
  #chat-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 6px;
    background: #fafafa;
    border-top: 1px solid #f0f0f0;
    flex-shrink: 0;
  }
  #chat-footer span {
    font-size: 0.65rem;
    color: #999;
  }

  /* Contact form */
  #contact-view {
    flex: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }
  #contact-view.chat-hidden { display: none; }

  #contact-form-wrapper { padding: 18px 16px; }
  #contact-intro {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 14px;
    line-height: 1.45;
  }

  #chat-contact-form label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    color: #444;
    margin-bottom: 4px;
    margin-top: 12px;
  }
  #chat-contact-form label:first-of-type { margin-top: 0; }
  .cf-req { color: #c0392b; }
  .cf-opt { font-weight: 400; color: #999; }

  #chat-contact-form input,
  #chat-contact-form textarea {
    width: 100%;
    padding: 9px 12px;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    font-size: 0.88rem;
    font-family: inherit;
    outline: none;
    background: #fafafa;
    transition: border-color 0.15s, background 0.15s;
  }
  #chat-contact-form input:focus,
  #chat-contact-form textarea:focus {
    border-color: #d4a843;
    background: #fff;
  }
  #chat-contact-form textarea { resize: vertical; min-height: 60px; }

  #cf-submit {
    width: 100%;
    margin-top: 16px;
    padding: 10px;
    background: #1a1a2e;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.88rem;
    font-family: inherit;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }
  #cf-submit:hover { background: #2d2d4e; }
  #cf-submit:disabled { opacity: 0.6; cursor: default; }

  #cf-status {
    margin-top: 8px;
    font-size: 0.82rem;
    line-height: 1.4;
    min-height: 1.2em;
  }
  #cf-status.success { color: #16a34a; }
  #cf-status.error { color: #c0392b; }

  @media (max-width: 480px) {
    #chat-panel {
      width: calc(100vw - 24px);
      height: calc(100dvh - 100px);
      right: -8px;
      bottom: 74px;
      border-radius: 16px;
    }
  }
</style>

<script>
  (function () {
    const API_URL = window.location.hostname === 'localhost' ? 'http://localhost:4061' : 'https://sandycoveschoolofmusic.com';
    const GREETING =
      "Hi! I can help with piano lessons, pricing, or getting started at Sandycove. What would you like to know?";
    const STORAGE_KEY = 'sandycove_chat';

    const bubble = document.getElementById('chat-bubble');
    const bubbleIcon = document.getElementById('chat-bubble-icon');
    const bubbleClose = document.getElementById('chat-bubble-close');
    const panel = document.getElementById('chat-panel');
    const closeBtn = document.getElementById('chat-close');
    const messagesEl = document.getElementById('chat-messages');
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('chat-send');
    const chatView = document.getElementById('chat-view');
    const contactView = document.getElementById('contact-view');
    const tabs = document.querySelectorAll('.chat-tab');
    const contactForm = document.getElementById('chat-contact-form');
    const cfStatus = document.getElementById('cf-status');

    let sessionId = null;
    let messages = [];
    let sending = false;
    let isOpen = false;

    // --- Tabs ---
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var target = tab.getAttribute('data-tab');
        tabs.forEach(function (t) { t.classList.toggle('active', t === tab); });
        if (target === 'chat') {
          chatView.classList.remove('chat-hidden');
          contactView.classList.add('chat-hidden');
          input.focus();
          messagesEl.scrollTop = messagesEl.scrollHeight;
        } else {
          chatView.classList.add('chat-hidden');
          contactView.classList.remove('chat-hidden');
          var nameField = document.getElementById('cf-name');
          if (nameField) nameField.focus();
        }
      });
    });

    // --- Contact Form ---
    contactForm.addEventListener('submit', async function (e) {
      e.preventDefault();
      cfStatus.textContent = '';
      cfStatus.className = '';

      var name = document.getElementById('cf-name').value.trim();
      var email = document.getElementById('cf-email').value.trim();
      var phone = document.getElementById('cf-phone').value.trim();
      var message = document.getElementById('cf-message').value.trim();

      if (!name) { cfStatus.textContent = 'Name is required.'; cfStatus.className = 'error'; return; }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { cfStatus.textContent = 'A valid email is required.'; cfStatus.className = 'error'; return; }
      if (!message) { cfStatus.textContent = 'Message is required.'; cfStatus.className = 'error'; return; }

      var submitBtn = document.getElementById('cf-submit');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        var res = await fetch(API_URL + '/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, email: email, phone: phone || undefined, message: message }),
        });
        var data = await res.json();

        if (res.ok && data.success) {
          cfStatus.textContent = "Message sent! We'll get back to you soon.";
          cfStatus.className = 'success';
          contactForm.reset();
        } else {
          cfStatus.textContent = data.error || 'Something went wrong. Please try again.';
          cfStatus.className = 'error';
        }
      } catch (_err) {
        cfStatus.textContent = "Couldn't send message. Call us on 086 872 9764.";
        cfStatus.className = 'error';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send message';
      }
    });

    // --- Chat ---
    function loadState() {
      try {
        var stored = sessionStorage.getItem(STORAGE_KEY);
        if (stored) {
          var state = JSON.parse(stored);
          sessionId = state.sessionId || null;
          messages = state.messages || [];
        }
      } catch (_e) {}

      if (messages.length === 0) {
        messages.push({ role: 'assistant', text: GREETING });
      }
      renderMessages();
    }

    function saveState() {
      try {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify({ sessionId: sessionId, messages: messages }));
      } catch (_e) {}
    }

    function makeAvatar(role) {
      var el = document.createElement('div');
      el.className = 'chat-msg-avatar';
      if (role === 'assistant') {
        el.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>';
      } else {
        el.textContent = 'You';
      }
      return el;
    }

    function renderMessages() {
      messagesEl.innerHTML = '';
      for (var i = 0; i < messages.length; i++) {
        var m = messages[i];
        var group = document.createElement('div');
        group.className = 'chat-msg-group ' + m.role;

        group.appendChild(makeAvatar(m.role));

        var content = document.createElement('div');
        content.className = 'chat-msg-content';

        var bbl = document.createElement('div');
        bbl.className = 'chat-msg-bubble';
        bbl.textContent = m.text;
        content.appendChild(bbl);

        group.appendChild(content);
        messagesEl.appendChild(group);
      }
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function showTyping() {
      var el = document.createElement('div');
      el.className = 'chat-typing';
      el.id = 'chat-typing-indicator';

      var av = document.createElement('div');
      av.className = 'chat-typing-avatar';
      av.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>';
      el.appendChild(av);

      var dots = document.createElement('div');
      dots.className = 'chat-typing-dots';
      dots.innerHTML = '<span></span><span></span><span></span>';
      el.appendChild(dots);

      messagesEl.appendChild(el);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function hideTyping() {
      var el = document.getElementById('chat-typing-indicator');
      if (el) el.remove();
    }

    async function sendMessage() {
      var text = input.value.trim();
      if (!text || sending) return;

      messages.push({ role: 'user', text: text });
      input.value = '';
      renderMessages();
      saveState();

      sending = true;
      showTyping();

      try {
        var res = await fetch(API_URL + '/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ sessionId: sessionId, message: text }),
        });
        var data = await res.json();

        if (data.sessionId) sessionId = data.sessionId;

        var reply = data.reply || data.error || 'Sorry, something went wrong. Please try again.';
        messages.push({ role: 'assistant', text: reply });
      } catch (_err) {
        messages.push({
          role: 'assistant',
          text: "I'm having trouble connecting. Feel free to call us on 086 872 9764!",
        });
      } finally {
        sending = false;
        hideTyping();
        renderMessages();
        saveState();
      }
    }

    function togglePanel() {
      isOpen = !isOpen;
      panel.classList.toggle('chat-hidden', !isOpen);
      bubbleIcon.style.display = isOpen ? 'none' : 'block';
      bubbleClose.style.display = isOpen ? 'block' : 'none';
      if (isOpen) {
        if (!contactView.classList.contains('chat-hidden')) {
          var nameField = document.getElementById('cf-name');
          if (nameField) nameField.focus();
        } else {
          input.focus();
          messagesEl.scrollTop = messagesEl.scrollHeight;
        }
      }
    }

    bubble.addEventListener('click', togglePanel);
    closeBtn.addEventListener('click', togglePanel);
    sendBtn.addEventListener('click', sendMessage);
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });

    loadState();
  })();
</script>
