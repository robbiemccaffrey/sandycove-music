---
---

<section class="relative pt-16 min-h-[85vh] flex items-center bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 overflow-hidden">
  <!-- Decorative music notes background -->
  <div class="absolute inset-0 opacity-[0.07]">
    <svg class="w-full h-full" viewBox="0 0 800 600" fill="white" xmlns="http://www.w3.org/2000/svg">
      <!-- Scattered music notes -->
      <g transform="translate(80,80) scale(1.5)">
        <path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
      </g>
      <g transform="translate(650,120) scale(2) rotate(15)">
        <path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
      </g>
      <g transform="translate(200,400) scale(1.8) rotate(-10)">
        <path d="M12 3v10.55A4 4 0 1014 17V7h4V3h-6z"/>
      </g>
      <g transform="translate(550,350) scale(1.3)">
        <path d="M12 3v10.55A4 4 0 1014 17V7h4V3h-6z"/>
      </g>
      <g transform="translate(400,100) scale(1.6) rotate(5)">
        <path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
      </g>
      <g transform="translate(100,300) scale(1.2) rotate(-5)">
        <path d="M12 3v10.55A4 4 0 1014 17V7h4V3h-6z"/>
      </g>
      <g transform="translate(700,450) scale(1.7) rotate(20)">
        <path d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
      </g>
      <!-- Treble clef large -->
      <g transform="translate(350,280) scale(4)" opacity="0.5">
        <path d="M12 3C11.2 3 10.5 3.3 10 3.8L8.6 5.2C8 5.8 7.6 6.6 7.6 7.4V9c0 .5.2 1 .6 1.4.4.4.9.6 1.4.6.4 0 .8-.1 1.1-.3l.3.9c-.5.3-.9.7-1.2 1.2-.3.5-.5 1-.5 1.6 0 .8.3 1.5.8 2 .5.5 1.2.8 2 .8s1.5-.3 2-.8c.5-.5.8-1.2.8-2"/>
      </g>
    </svg>
  </div>

  <!-- Piano keys decoration at bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-16 opacity-20">
    <img src="/images/piano-keys.svg" alt="" class="w-full h-full object-cover object-top" aria-hidden="true" />
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
    <div class="inline-flex items-center gap-2 mb-8 px-5 py-2.5 rounded-full bg-gold-500/20 border border-gold-400/40">
      <svg class="w-5 h-5 text-gold-300" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 3v10.55A4 4 0 1014 17V7h4V3h-6z"/>
      </svg>
      <span class="text-gold-200 font-semibold text-sm sm:text-base">Get 50% off your first lesson</span>
    </div>
    <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-white leading-tight mb-6" style="font-family: 'Playfair Display', Georgia, serif;">
      Sandycove School<br />of Music
    </h1>
    <p class="text-xl sm:text-2xl text-navy-200 max-w-2xl mx-auto mb-10 leading-relaxed">
      Tailored, effective tutoring to help you reach your potential.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#contact"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full text-lg font-semibold bg-gold-500 text-white hover:bg-gold-600 transition-colors shadow-lg shadow-gold-500/25"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Book a Lesson
      </a>
      <a
        href="#lessons"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full text-lg font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-colors"
      >
        Learn More
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
