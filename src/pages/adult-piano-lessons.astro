---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';

const faqs = [
  {
    question: "I've never played before — is it too late to start?",
    answer: "Absolutely not. Many of our adult students are complete beginners who are picking up the piano for the first time. Adults bring focus, motivation, and a lifetime of listening to music — all of which help you progress faster than you might expect.",
  },
  {
    question: 'How long does it take an adult to learn piano?',
    answer: "Within a few months of weekly lessons and regular practice, most adult beginners can play simple pieces with both hands. Within a year, you'll have a small repertoire and a solid foundation in technique and music reading. Progress depends on practice — even 15–20 minutes a day makes a real difference.",
  },
  {
    question: 'Do I need my own piano at home?',
    answer: "You'll need something to practise on. A full-size digital piano with weighted keys is a great starting point — you can pick one up from around €400–€700. We're happy to recommend specific models if you need guidance.",
  },
  {
    question: 'Do I have to do exams?',
    answer: "Not at all. Exams are entirely optional. Many of our adult students prefer to learn the music they love without the pressure of formal exams. Others enjoy the structure and sense of achievement that grades provide. It's completely up to you.",
  },
  {
    question: 'What styles can I learn?',
    answer: "Whatever you like. Classical, jazz, pop, film music, contemporary — we build your lessons around your musical interests. Many adult students enjoy a mix of styles, and we'll help you find what suits you best.",
  },
  {
    question: 'Do you offer online lessons for adults?',
    answer: "Yes. Our online piano lessons work particularly well for adults who have busy schedules or prefer to learn from home. They follow the same structure and standard as in-person sessions, delivered via video call.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Adult Piano Lessons',
  name: 'Adult Piano Lessons in Dublin',
  description: 'Piano lessons for adults in Dublin. Complete beginners welcome. Classical, jazz, pop — learn at your own pace. In-person in Sandycove or online. From €30.',
  provider: {
    '@type': 'MusicSchool',
    name: 'Sandycove School of Music',
    url: 'https://sandycoveschoolofmusic.com',
    telephone: '+353868729764',
  },
  areaServed: [
    { '@type': 'City', name: 'Dublin' },
    { '@type': 'City', name: 'Dun Laoghaire' },
    { '@type': 'City', name: 'Sandycove' },
    { '@type': 'City', name: 'Dalkey' },
    { '@type': 'City', name: 'Glasthule' },
    { '@type': 'City', name: 'Blackrock' },
  ],
  offers: [
    { '@type': 'Offer', name: '30-Minute Piano Lesson', price: '30', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: '40-Minute Piano Lesson', price: '40', priceCurrency: 'EUR' },
    { '@type': 'Offer', name: '1-Hour Piano Lesson', price: '50', priceCurrency: 'EUR' },
  ],
};

const courseSchema = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Adult Piano Lessons',
  description: 'One-on-one piano lessons for adults in Dublin. Beginners welcome. Classical, jazz, pop — learn at your own pace with flexible scheduling.',
  provider: {
    '@type': 'MusicSchool',
    name: 'Sandycove School of Music',
    url: 'https://sandycoveschoolofmusic.com',
  },
  offers: {
    '@type': 'Offer',
    price: '30',
    priceCurrency: 'EUR',
  },
};

const individual = [
  { duration: '30 minutes', price: '€30' },
  { duration: '40 minutes', price: '€40' },
  { duration: '1 hour', price: '€50' },
];

const packages = [
  { sessions: '10 × 30 min', price: '€270', saving: 'Save €30' },
  { sessions: '10 × 40 min', price: '€330', saving: 'Save €70' },
  { sessions: '10 × 1 hour', price: '€400', saving: 'Save €100' },
];
---

<Layout
  title="Adult Piano Lessons Dublin | Beginners Welcome | Sandycove Music"
  description="Adult piano lessons in Dublin for complete beginners and returners. Learn at your own pace. Classical, jazz, pop. In-person or online. From €30. Free trial."
>
  <Header />
  <main class="flex-1">
    <!-- Hero -->
    <section class="relative pt-16 py-20 bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_40%,_rgba(201,149,46,0.07)_0%,_transparent_60%)]"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-16">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6" style="font-family: 'Playfair Display', Georgia, serif;">
          Adult Piano Lessons in Dublin
        </h1>
        <p class="text-xl sm:text-2xl text-navy-200 max-w-2xl mx-auto mb-8 leading-relaxed">
          It's never too late to learn piano. Relaxed, one-on-one lessons tailored to your goals — from complete beginners to returning players.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full text-lg font-semibold bg-gold-500 text-white hover:bg-gold-600 transition-colors shadow-lg shadow-gold-500/25">
            Book a Free Trial
          </a>
          <a href="#pricing" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full text-lg font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-colors">
            View Pricing
          </a>
        </div>
      </div>
    </section>

    <!-- Intro -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <p class="text-navy-700 text-lg leading-relaxed mb-6">
            Whether you've always wanted to learn piano, played as a child and want to pick it up again, or simply fancy a new challenge — you're in the right place. At Sandycove School of Music, a large number of our students are adults, and we tailor every lesson to your pace, your interests, and your goals.
          </p>
          <p class="text-navy-700 text-lg leading-relaxed">
            There's no pressure, no rushing, and no exams unless you want them. Just enjoyable, focused tuition that helps you make real progress — whether that's playing your favourite songs, learning to read music, or working through the grades. Lessons are available in-person at our Sandycove studio or online via video call.
          </p>
        </div>
      </div>
    </section>

    <!-- Why Adults Learn Piano -->
    <section class="py-20 bg-navy-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-4" style="font-family: 'Playfair Display', Georgia, serif;">Why Adults Make Great Piano Students</h2>
          <div class="w-16 h-1 bg-gold-500 mx-auto"></div>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {[
            { title: 'Motivation', desc: "You're choosing to do this — that intrinsic motivation is incredibly powerful and will carry you through the early stages far more effectively than external pressure." },
            { title: 'Musical Experience', desc: "You've spent decades listening to music. That intuitive sense of melody, rhythm, and expression accelerates your learning enormously." },
            { title: 'Focus & Discipline', desc: 'Adults can concentrate for longer, understand abstract concepts more easily, and follow structured practice plans. Theory clicks faster.' },
            { title: 'Clear Goals', desc: 'Most adult learners know what they want — whether it\'s playing favourite songs, working through grades, or just enjoying a creative hobby.' },
            { title: 'Flexible Scheduling', desc: 'Morning, afternoon, evening, and Saturday slots available. We work around your commitments, not the other way around.' },
            { title: 'Online Option', desc: "Can't make it to the studio? Our online lessons are just as structured and effective — perfect for busy schedules." },
          ].map(({ title, desc }) => (
            <div class="p-6 rounded-2xl bg-white border border-navy-100 hover:border-gold-400 hover:shadow-lg transition-all">
              <h3 class="text-lg font-semibold text-navy-900 mb-2">{title}</h3>
              <p class="text-navy-500 text-sm leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What to Expect -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-4" style="font-family: 'Playfair Display', Georgia, serif;">What an Adult Lesson Looks Like</h2>
            <div class="w-16 h-1 bg-gold-500 mb-6"></div>
            <p class="text-navy-700 leading-relaxed mb-6">
              Every lesson is one-on-one and tailored to you. We start by understanding what you want to achieve, then build a programme around that — whether it's classical pieces, jazz standards, pop songs, or a bit of everything.
            </p>
            <p class="text-navy-700 leading-relaxed mb-6">
              A typical lesson includes a mix of technique work, new pieces, and music theory — all in a relaxed, supportive environment. You'll leave each session with clear practice goals so you know exactly what to work on at home.
            </p>
            <a href="/contact" class="inline-flex items-center gap-2 text-gold-600 hover:text-gold-700 font-semibold transition-colors">
              Book your first lesson
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
          <div class="space-y-4">
            {[
              { title: 'Beginners: Weeks 1–4', desc: 'Hand position, reading simple notation, playing with each hand separately. Building the foundation that everything else rests on.' },
              { title: 'Months 2–3', desc: 'Playing with both hands together, learning chords, tackling pieces that actually sound like music. This is where the first real buzz kicks in.' },
              { title: 'Months 4–6', desc: 'A small repertoire of pieces, working knowledge of music theory, and the skills to start exploring the styles you love most.' },
            ].map(({ title, desc }) => (
              <div class="flex items-start gap-4 p-4 rounded-xl bg-navy-50 border border-navy-100">
                <div class="w-8 h-8 rounded-lg bg-gold-50 border border-gold-200 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-gold-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                </div>
                <div>
                  <h3 class="font-semibold text-navy-900">{title}</h3>
                  <p class="text-navy-500 text-sm">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Choose Your Style -->
    <section class="py-20 bg-navy-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-4" style="font-family: 'Playfair Display', Georgia, serif;">Choose Your Style</h2>
          <div class="w-16 h-1 bg-gold-500 mx-auto mb-6"></div>
          <p class="text-navy-600 text-lg">One of the great things about learning as an adult is that you get to choose what you play.</p>
        </div>
        <div class="max-w-3xl mx-auto">
          <div class="grid sm:grid-cols-2 gap-4">
            {[
              { title: 'Classical', desc: 'Build technique and discipline with the great composers.' },
              { title: 'Jazz & Blues', desc: 'Learn standards, improvisation, and chord-based playing.' },
              { title: 'Pop & Contemporary', desc: 'Play the songs you love — from Coldplay to Einaudi.' },
              { title: 'Film & TV Music', desc: 'Iconic soundtracks and themes that are deeply satisfying to play.' },
            ].map(({ title, desc }) => (
              <div class="p-5 rounded-xl bg-white border border-navy-100 hover:border-gold-400 hover:shadow-sm transition-all">
                <h3 class="font-semibold text-navy-900 mb-1">{title}</h3>
                <p class="text-navy-500 text-sm">{desc}</p>
              </div>
            ))}
          </div>
          <p class="text-navy-700 text-lg leading-relaxed text-center mt-8">
            Most of our adult students enjoy a mix. We'll help you find what suits you and build a programme that keeps you motivated.
          </p>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-4" style="font-family: 'Playfair Display', Georgia, serif;">Piano Lesson Pricing</h2>
          <div class="w-16 h-1 bg-gold-500 mx-auto mb-6"></div>
          <p class="text-navy-600 text-lg">Simple, transparent pricing. Save with our 10-lesson packages.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <div class="rounded-2xl border border-navy-200 bg-white p-8 shadow-sm">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-lg bg-navy-50 flex items-center justify-center">
                <svg class="w-5 h-5 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v10.55A4 4 0 1014 17V7h4V3h-6z"/>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-navy-900">Individual Lessons</h3>
            </div>
            <div class="space-y-4">
              {individual.map(({ duration, price }) => (
                <div class="flex items-center justify-between py-3 border-b border-navy-100 last:border-0">
                  <span class="text-navy-600">{duration}</span>
                  <span class="text-xl font-bold text-navy-900">{price}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="rounded-2xl border-2 border-gold-400 bg-gold-50/50 p-8 shadow-sm relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-gold-500 text-white text-xs font-bold rounded-full uppercase tracking-wider shadow-sm">
              Best Value
            </div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-lg bg-gold-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-gold-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-navy-900">Lesson Packages</h3>
            </div>
            <div class="space-y-4">
              {packages.map(({ sessions, price, saving }) => (
                <div class="flex items-center justify-between py-3 border-b border-gold-200 last:border-0">
                  <div>
                    <span class="text-navy-700 block">{sessions}</span>
                    <span class="text-gold-600 text-xs font-semibold">{saving}</span>
                  </div>
                  <span class="text-xl font-bold text-navy-900">{price}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <p class="text-center text-navy-400 text-sm mt-8">
          All prices are inclusive. Call-out lessons available for an additional €5 per lesson.
        </p>
      </div>
    </section>

    <!-- Related Pages -->
    <section class="py-16 bg-navy-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center mb-8">
          <h2 class="text-2xl font-bold text-navy-900 mb-4" style="font-family: 'Playfair Display', Georgia, serif;">You Might Also Be Interested In</h2>
          <div class="w-16 h-1 bg-gold-500 mx-auto"></div>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto">
          {[
            { href: '/piano-lessons', label: 'Piano Lessons Overview' },
            { href: '/piano-lessons-dun-laoghaire', label: 'Lessons in Dun Laoghaire' },
            { href: '/piano-lessons-dalkey', label: 'Lessons near Dalkey' },
            { href: '/piano-lessons-glasthule', label: 'Lessons in Glasthule' },
          ].map(({ href, label }) => (
            <a href={href} class="flex items-center gap-2 p-4 rounded-xl bg-white border border-navy-100 hover:border-gold-400 hover:shadow-sm transition-all text-navy-700 font-medium text-sm">
              <svg class="w-4 h-4 text-gold-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              {label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy-900 mb-4" style="font-family: 'Playfair Display', Georgia, serif;">Adult Piano Lessons — FAQs</h2>
          <div class="w-16 h-1 bg-gold-500 mx-auto mb-6"></div>
        </div>
        <div class="space-y-4">
          {faqs.map(({ question, answer }) => (
            <details class="group rounded-2xl border border-navy-100 bg-navy-50 shadow-sm overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-left font-semibold text-navy-900 hover:text-gold-600 transition-colors">
                <span>{question}</span>
                <svg class="w-5 h-5 text-navy-400 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="px-6 pb-5 text-navy-600 leading-relaxed">
                {answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-navy-900">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4" style="font-family: 'Playfair Display', Georgia, serif;">Ready to Start Playing?</h2>
        <div class="w-16 h-1 bg-gold-500 mx-auto mb-6"></div>
        <p class="text-navy-200 text-lg mb-8 max-w-2xl mx-auto">
          Book a free trial lesson — no experience needed. We'll find out what you want to achieve and get you started straight away.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full text-lg font-semibold bg-gold-500 text-white hover:bg-gold-600 transition-colors shadow-lg shadow-gold-500/25">
            Book a Free Trial
          </a>
          <a href="tel:+353868729764" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full text-lg font-semibold border-2 border-white/30 text-white hover:bg-white/10 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Call 086 872 9764
          </a>
        </div>
      </div>
    </section>

    <ContactForm />
  </main>
  <Footer />
  <LocalBusinessSchema />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />
</Layout>
